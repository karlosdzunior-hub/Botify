# ══════════════════════════════════════════
#  Botify — переменные окружения для VPS
#  Скопируй этот файл в .env и заполни
# ══════════════════════════════════════════

# ─── Telegram ──────────────────────────────
# Токен главного бота Botify (получить у @BotFather)
MAIN_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Твой Telegram ID (узнать у @userinfobot)
ADMIN_USER_ID=123456789

# HTTPS URL твоего домена — куда откроется мини-апп
MINI_APP_URL=https://yourdomain.com

# ─── База данных ───────────────────────────
# Пароль PostgreSQL (придумай сам, мин. 16 символов)
POSTGRES_PASSWORD=super_secret_password_here

# ─── Безопасность ──────────────────────────
# Секрет для JWT сессий (сгенерируй: openssl rand -hex 32)
SESSION_SECRET=replace_with_64_char_random_hex_string

# Ключ шифрования токенов ботов (сгенерируй: openssl rand -base64 32)
FERNET_KEY=replace_with_base64_32_bytes

# ─── ИИ провайдеры ─────────────────────────
# Groq API (бесплатно): https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini API (бесплатно): https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ─── Платежи — ЮМани (рекомендуется) ──────
# Номер кошелька ЮМани (410011XXXXXXXXX)
# Найти в личном кабинете: https://yoomoney.ru
# Регистрация ИП/ООО НЕ нужна!
YUMONEY_WALLET=410011000000000

# Секрет для проверки уведомлений от ЮМани
# Установить в: yoomoney.ru → Настройки → HTTP-уведомления → Секретный ключ
# URL уведомлений: https://yourdomain.com/api/payments/yumoney/webhook
YUMONEY_NOTIFICATION_SECRET=your_notification_secret

# ─── Настройки ─────────────────────────────
# Кредиты при регистрации нового пользователя
CREDITS_ON_REGISTER=30

# Домен для SSL сертификата (без https://)
DOMAIN=yourdomain.com
